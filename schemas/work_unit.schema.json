{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LiemWorkUnit",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "trace_id": { "type": "string" },
    "execution_id": { "type": "string" },
    "task_id": { "type": "string" },
    "inputs": { "type": "object" },
    "artifacts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "constraints": {
      "type": "object",
      "properties": {
        "timeout_seconds": { "type": "integer" },
        "max_cost_usd": { "type": "number" }
      },
      "required": ["timeout_seconds"]
    },
    "expected_outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["SOURCE", "REPORT", "MODEL", "CONFIG", "STATE"] },
          "schema_ref": { "type": "string" }
        },
        "required": ["type"]
      }
    }
  },
  "required": ["id", "trace_id", "execution_id", "task_id", "inputs", "artifacts", "constraints", "expected_outputs"]
}
